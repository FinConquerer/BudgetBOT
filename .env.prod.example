# Mẫu biến môi trường PRODUCTION. Sao chép thành .env.prod trên server và điền giá trị thật.
# TUYỆT ĐỐI KHÔNG commit .env.prod (đã nằm trong .gitignore).

ENVIRONMENT=production

# Database sẵn có. Nếu Postgres chạy ngay trên host, dùng host.docker.internal:
DATABASE_URL=postgresql+psycopg://budgetbot_user:CHANGE_ME@host.docker.internal:5432/budgetbot_db
# Hoặc dùng IP/hostname của DB nếu ở nơi khác:
# DATABASE_URL=postgresql+psycopg://budgetbot_user:CHANGE_ME@<db-host>:5432/budgetbot_db

# Khoá ký JWT — BẮT BUỘC đổi thành chuỗi ngẫu nhiên dài (openssl rand -hex 32).
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Domain/origin của frontend (để CORS). Nếu frontend cùng origin qua nginx thì để domain thật.
CORS_ORIGINS=https://your-domain.com
