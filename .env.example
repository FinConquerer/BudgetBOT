ENVIRONMENT=development

# Local Docker defaults. Replace values in your private .env file.
POSTGRES_USER=budgetbot
POSTGRES_PASSWORD=budgetbot
POSTGRES_DB=budgetbot

# Use postgresql+psycopg for SQLAlchemy with psycopg v3.
DATABASE_URL=postgresql+psycopg://budgetbot:budgetbot@localhost:5432/budgetbot

# Never commit a real production secret.
SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

CORS_ORIGINS=http://localhost:5173
VITE_API_BASE=/api
